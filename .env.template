# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/rural_digital_rights
DATABASE_ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Vector Database (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX_NAME=government-schemes

# OpenAI API
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# Speech Services
GOOGLE_STT_API_KEY=your-google-stt-api-key
GOOGLE_TTS_API_KEY=your-google-tts-api-key

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# AWS S3 (for audio storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=rural-digital-rights-audio

# Monitoring
PROMETHEUS_PORT=9090

# Database Read Replicas (comma-separated)
DATABASE_READ_REPLICA_URLS=postgresql://user:password@replica1:5432/rural_digital_rights,postgresql://user:password@replica2:5432/rural_digital_rights

# CDN Configuration
CDN_URL=https://cdn.rural-digital-rights.example.com
